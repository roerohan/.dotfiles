{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    "@plannotator/opencode@latest"
  ],
  "model": "openai/gpt-5.5",
  "permission": {
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "ls *": "allow",
      "ls": "allow",
      "echo *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "sort *": "allow",
      "wc *": "allow",
      "stat *": "allow",
      "file *": "allow",
      "which *": "allow",
      "pwd": "allow",
      "env": "allow",
      "printenv *": "allow",
      "diff": "allow",
      "git branch *": "allow",
      "git diff *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git rev-parse *": "allow",
      "git remote get-url *": "allow",
      "pnpm lint *": "allow",
      "pnpm format *": "allow",
      "npm lint *": "allow",
      "npm format *": "allow"
    },
    "edit": "allow",
    "webfetch": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "question": "allow",
    "task": "allow",
    "skill": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.envrc": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/.envrc": "deny",
      ".dev.vars": "deny",
      "**/.dev.vars": "deny",
      "secrets/*": "deny",
      "**/secrets/**": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "**/.aws/**": "deny",
      "**/.ssh/**": "deny",
      "$HOME/.local/share/opencode/mcp-auth.json": "deny",
      "~/.local/share/opencode/mcp-auth.json": "deny"
    },
    "external_directory": {
      "*": "ask",
      "~/.local/share/opencode/*": "deny",
      "**/.ssh/**": "deny",
      "**/.aws/**": "deny",
    }
  }
}
